# ===========================================
# Database
# ===========================================
# Connection string for your PostgreSQL database
# Neon:        postgresql://user:pass@ep-xxx.region.neon.tech/dbname?sslmode=require
# Self-hosted: postgresql://user:pass@localhost:5432/dbname
DATABASE_URL=

# ===========================================
# Authentication (NextAuth + Zitadel OIDC)
# ===========================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Zitadel OIDC configuration
AUTH_ZITADEL_ISSUER=https://your-instance.zitadel.cloud
AUTH_ZITADEL_CLIENT_ID=
AUTH_ZITADEL_CLIENT_SECRET=

# NextAuth URL (set to your app's base URL)
NEXTAUTH_URL=http://localhost:3000

# ===========================================
# Public (exposed to browser)
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ===========================================
# Optional
# ===========================================
# Turbo remote cache
# TURBO_TOKEN=
# TURBO_TEAM=

# Skip env validation during Docker builds
# SKIP_ENV_VALIDATION=true
